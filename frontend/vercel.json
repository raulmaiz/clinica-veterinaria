{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/clinica-veterinaria-frontend/browser",
  "installCommand": "npm install --legacy-peer-deps",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://RAILWAY-URL/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
